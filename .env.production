# Production build environment — read by Vite when running `npm run build`
# (and therefore by `npm run deploy`). Marketing site is at outworx.ai;
# the app + API live at app.outworx.ai, so every CTA + API fetch needs
# the cross-origin URL baked into the build.
VITE_APP_URL=https://app.outworx.ai
VITE_API_BASE_URL=https://app.outworx.ai
