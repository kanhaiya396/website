# Outworx marketing site — environment variables

# Where the app lives. Used by every CTA/link on the marketing site that
# hands the visitor off to authenticated app pages (login, signup, demo,
# integrations deep-link). Production default points to the deployed app
# domain; for local dev, point this at your local app dev server.
VITE_APP_URL=https://app.outworx.ai
# VITE_APP_URL=http://localhost:3000

# Base URL for backend API calls (currently just the public
# subscription-plans endpoint on the Pricing page). Empty string means
# "same origin", which works in dev because the Vite proxy in
# vite.config.ts forwards /api to http://localhost:8000. In production
# the marketing site is on outworx.ai but the API lives on
# app.outworx.ai — set this to the full origin so fetches go cross-origin
# directly to the backend (Django must allow outworx.ai in
# CORS_ALLOWED_ORIGINS for this to succeed).
VITE_API_BASE_URL=
# VITE_API_BASE_URL=https://app.outworx.ai
